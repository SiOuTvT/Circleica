# ═══════════════════════════════════════════
# 同人游戏站 Docker 部署配置
# 复制此文件为 .env 并填写配置
# ═══════════════════════════════════════════

# ── 数据库连接（必填）──
# 连接宿主机上已有的 PostgreSQL
# 格式: postgresql://用户名:密码@host.docker.internal:端口/数据库名
DATABASE_URL=postgresql://fangame:你的数据库密码@host.docker.internal:5432/fangame

# ── 应用配置（必填）──
# NextAuth 密钥（用于加密会话，请使用随机字符串）
# 生成命令: openssl rand -base64 32
NEXTAUTH_SECRET=在此设置一个随机密钥至少32字符
# 网站访问地址（必须与实际访问地址完全一致，包含协议和端口）
NEXTAUTH_URL=http://你的服务器IP

# ── 端口配置 ──
# 应用对外端口（80 = HTTP 标准端口，用户无需输入端口号）
APP_PORT=80

# ═══════════════════════════════════════════
# 以下为可选配置，不填则使用默认行为
# ═══════════════════════════════════════════

# ── Sentry 错误监控（可选）──
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ── Cloudflare R2 文件存储（可选，不填则使用本地存储）──
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_ACCESS_KEY_SECRET=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ── UploadThing 文件上传（可选）──
# UPLOADTHING_TOKEN=

# ── Resend 邮件服务（可选，用于密码重置邮件）──
# RESEND_API_KEY=

# ── Turnstile 验证码（可选，用于注册防机器人）──
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
